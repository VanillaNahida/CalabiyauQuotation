<Window x:Class="CalabiyauQuotation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        xmlns:ctrl="clr-namespace:CalabiyauQuotation.Controls"
        Title="喵语生成器 By 香草味的纳西妲喵(VanillaNahida)" Height="471" Width="540"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Closing="Window_Closing">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Generic.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="1" Margin="10" x:Name="tabControl" SelectionChanged="TabControl_SelectionChanged">
            <TabItem Header="主界面">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <GroupBox Header="随机喵语" Grid.Row="0">
                        <TextBox x:Name="txtSentence" 
                                 TextWrapping="Wrap" 
                                 AcceptsReturn="True" 
                                 VerticalScrollBarVisibility="Auto"
                                 IsReadOnly="True"
                                 Margin="5"/>
                    </GroupBox>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                        <Button x:Name="btnGenerate" Content="换一个喵" Width="120" Height="35" Margin="5" Click="BtnGenerate_Click"/>
                        <Button x:Name="btnCopy" Content="一键复制喵" Width="120" Height="35" Margin="5" Click="BtnCopy_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="设置">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <GroupBox Header="全局粘贴快捷键设置" Margin="0,0,0,10">
                            <StackPanel Margin="5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="快捷键:" VerticalAlignment="Center" Margin="5"/>
                                    <ctrl:HotKeyBox x:Name="hkHotkey" Grid.Column="1" Margin="5" Height="26" HotKeyChanged="HotKeyBox_HotKeyChanged"/>
                                </Grid>
                                <CheckBox x:Name="chkClearAndPaste" Content="清空输入框并重新粘贴" Margin="5,10,5,5" IsChecked="True" Checked="Setting_Changed" Unchecked="Setting_Changed"/>
                                <CheckBox x:Name="chkAutoSend" Content="自动发送（粘贴后按下Enter）" Margin="5,5,5,5" Checked="Setting_Changed" Unchecked="Setting_Changed"/>
                                <TextBlock Text="提示：推荐使用包含 Ctrl、Alt、Shift 或 Win 的组合键以避免与系统快捷键冲突" 
                                           FontSize="11" Foreground="Gray" Margin="5,5,5,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="词库设置" Margin="0,0,0,10">
                            <StackPanel Margin="5">
                                <CheckBox x:Name="chkEnableAutoDownload" Content="启动时自动更新词库" Margin="5" Checked="Setting_Changed" Unchecked="Setting_Changed"/>
                                <TextBlock Text="词库地址:" Margin="5,10,5,0"/>
                                <TextBox x:Name="txtDictionaryUrl" Margin="5" TextChanged="Setting_Changed"/>
                                <Button x:Name="btnDownload" Content="手动更新词库" Width="150" Height="30" Margin="5" HorizontalAlignment="Left" Click="BtnDownload_Click"/>
                            </StackPanel>
                        </GroupBox>
                        <Button x:Name="btnSaveSettings" Content="保存设置" Width="150" Height="35" Click="BtnSaveSettings_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="关于">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Image Grid.Column="0" x:Name="aboutImage" Source="Assets\AppIcon.ico" Width="80" Margin="10,20,10,242" Cursor="Hand" MouseLeftButtonUp="Image_MouseLeftButtonUp"/>

                    <StackPanel Grid.Column="1" Margin="10">
                        <TextBlock Text="喵语生成器" FontSize="18" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBlock Text="版本: 1.0.1" FontSize="14" Margin="0,0,0,5"/>
                        <TextBlock Text="一个用于快捷粘贴随机喵语的小工具喵~" TextWrapping="Wrap" Margin="0,0,0,10"/>

                        <TextBlock Text="程序作者: 香草味的纳西妲喵(VanillaNahida)" TextWrapping="Wrap" Margin="0,0,0,5"/>
                        <TextBlock Text="GitHub仓库" TextDecorations="Underline" Foreground="Blue" Cursor="Hand" Margin="0,0,0,5" MouseLeftButtonUp="GitHubUrl_Click"/>
                        <TextBlock Text="作者B站主页" TextDecorations="Underline" Foreground="Blue" Cursor="Hand" Margin="0,0,0,5" MouseLeftButtonUp="BilibiliUrl_Click"/>
                        <TextBlock Text="加入作者的QQ群喵（点我前往群组列表）" TextDecorations="Underline" Foreground="Blue" Cursor="Hand" FontSize="15" Margin="0,0,0,5" MouseLeftButtonUp="QQGroupUrl_Click"/>
                        <TextBox Text="香草の小黑屋（B站一群）：621457510" FontSize="14" Margin="0,5,0,3" IsReadOnly="True" BorderThickness="0" Background="Transparent" Padding="0"/>
                        <TextBox Text="香草的技术部（B站二群）：1031065631" FontSize="14" Margin="0,0,0,3" IsReadOnly="True" BorderThickness="0" Background="Transparent" Padding="0"/>
                        <TextBox Text="香草的AI工坊（B站三群）：195260107" FontSize="14" Margin="0,0,0,3" IsReadOnly="True" BorderThickness="0" Background="Transparent" Padding="0"/>
                        <TextBox Text="香草的Ubuntu服务器小屋（B站四群）：1074471035" FontSize="14" Margin="0,0,0,3" IsReadOnly="True" BorderThickness="0" Background="Transparent" Padding="0"/>
                        <TextBox Text="香草的喵喵军团：1067451762" FontSize="14" Margin="0,0,0,3" IsReadOnly="True" BorderThickness="0" Background="Transparent" Padding="0"/>
                        <TextBox Text="纳西妲厨聚集地：814061421" FontSize="14" Margin="0,0,0,3" IsReadOnly="True" BorderThickness="0" Background="Transparent" Padding="0"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <TextBlock x:Name="txtStatus" Text="就绪"/>
            </StatusBarItem>
        </StatusBar>

        <tb:TaskbarIcon x:Name="taskbarIcon" 
                        IconSource="Assets\AppIcon.ico"
                        ToolTipText="宝宝我会一直的看着你喵~"
                        TrayLeftMouseDown="TaskbarIcon_TrayLeftMouseDown"
                        TrayRightMouseDown="TaskbarIcon_TrayRightMouseDown">
        </tb:TaskbarIcon>
    </Grid>
</Window>
