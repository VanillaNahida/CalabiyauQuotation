<Window x:Class="CalabiyauQuotation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        xmlns:ctrl="clr-namespace:CalabiyauQuotation.Controls"
        xmlns:properties="clr-namespace:CalabiyauQuotation.Properties"
        Title="{x:Static properties:Resources.AppTitle}" Height="545" Width="540"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Closing="Window_Closing">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Generic.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="1" Margin="10" x:Name="tabControl" SelectionChanged="TabControl_SelectionChanged">
            <TabItem Header="{x:Static properties:Resources.TabMain}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <GroupBox Header="{x:Static properties:Resources.GroupRandomCatLanguage}" Grid.Row="0">
                        <TextBox x:Name="txtSentence" 
                                 TextWrapping="Wrap" 
                                 AcceptsReturn="True" 
                                 VerticalScrollBarVisibility="Auto"
                                 IsReadOnly="True"
                                 Margin="5"/>
                    </GroupBox>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                        <Button x:Name="btnGenerate" Content="{x:Static properties:Resources.BtnGenerate}" Width="120" Height="35" Margin="5" Click="BtnGenerate_Click"/>
                        <Button x:Name="btnCopy" Content="{x:Static properties:Resources.BtnCopy}" Width="120" Height="35" Margin="5" Click="BtnCopy_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="{x:Static properties:Resources.TabSettings}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <GroupBox Header="{x:Static properties:Resources.GroupGlobalHotkey}" Margin="0,0,0,10">
                            <StackPanel Margin="5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="{x:Static properties:Resources.LabelHotkey}" VerticalAlignment="Center" Margin="5"/>
                                    <ctrl:HotKeyBox x:Name="hkHotkey" Grid.Column="1" Margin="5" Height="26" HotKeyChanged="HotKeyBox_HotKeyChanged"/>
                                </Grid>
                                <CheckBox x:Name="chkClearAndPaste" Content="{x:Static properties:Resources.ChkClearAndPaste}" Margin="5,10,5,5" IsChecked="True" Checked="Setting_Changed" Unchecked="Setting_Changed"/>
                                <CheckBox x:Name="chkAutoSend" Content="{x:Static properties:Resources.ChkAutoSend}" Margin="5,5,5,5" Checked="Setting_Changed" Unchecked="Setting_Changed"/>
                                <TextBlock Text="{x:Static properties:Resources.HintHotkey}" 
                                           FontSize="11" Foreground="Gray" Margin="5,5,5,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="{x:Static properties:Resources.GroupDictionary}" Margin="0,0,0,10">
                            <StackPanel Margin="5">
                                <CheckBox x:Name="chkEnableAutoDownload" Content="{x:Static properties:Resources.ChkEnableAutoDownload}" Margin="5" Checked="Setting_Changed" Unchecked="Setting_Changed"/>
                                <TextBlock Text="{x:Static properties:Resources.LabelDictionaryUrl}" Margin="5,10,5,0"/>
                                <TextBox x:Name="txtDictionaryUrl" Margin="5" TextChanged="Setting_Changed"/>
                                <Button x:Name="btnDownload" Content="{x:Static properties:Resources.BtnDownload}" Width="150" Height="30" Margin="5" HorizontalAlignment="Left" Click="BtnDownload_Click"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="{x:Static properties:Resources.GroupLanguage}" Margin="0,0,0,10">
                            <StackPanel Margin="5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="{x:Static properties:Resources.LabelLanguage}" VerticalAlignment="Center" Margin="5"/>
                                    <ComboBox x:Name="cmbLanguage" Grid.Column="1" Margin="5" Height="26" SelectionChanged="CmbLanguage_SelectionChanged">
                                        <ComboBoxItem Content="{x:Static properties:Resources.LanguageAuto}" Tag="auto"/>
                                        <ComboBoxItem Content="{x:Static properties:Resources.LanguageChinese}" Tag="zh-CN"/>
                                        <ComboBoxItem Content="{x:Static properties:Resources.LanguageEnglish}" Tag="en"/>
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </GroupBox>
                        
                        <Button x:Name="btnSaveSettings" Content="{x:Static properties:Resources.BtnSaveSettings}" Width="150" Height="35" Click="BtnSaveSettings_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="{x:Static properties:Resources.TabAbout}">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Image Grid.Column="0" x:Name="aboutImage" Source="Assets\AppIcon.ico" Width="80" Margin="10,20,10,242" Cursor="Hand" MouseLeftButtonUp="Image_MouseLeftButtonUp"/>

                    <StackPanel Grid.Column="1" Margin="10,10,10,10">
                        <TextBlock Text="{x:Static properties:Resources.AppName}" FontSize="18" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBlock Text="{x:Static properties:Resources.Version}" FontSize="14" Margin="0,0,0,5"/>
                        <TextBlock Text="{x:Static properties:Resources.AppDescription}" TextWrapping="Wrap" Margin="0,0,0,10"/>

                        <TextBlock Text="{x:Static properties:Resources.Author}" TextWrapping="Wrap" Margin="0,0,0,5"/>
                        <TextBlock Text="{x:Static properties:Resources.GitHubRepo}" TextDecorations="Underline" Foreground="Blue" Cursor="Hand" Margin="0,0,0,5" MouseLeftButtonUp="GitHubUrl_Click"/>
                        <TextBlock Text="{x:Static properties:Resources.BilibiliHomepage}" TextDecorations="Underline" Foreground="Blue" Cursor="Hand" Margin="0,0,0,5" MouseLeftButtonUp="BilibiliUrl_Click"/>
                        <TextBlock Text="{x:Static properties:Resources.QQGroups}" TextDecorations="Underline" Foreground="Blue" Cursor="Hand" FontSize="15" Margin="0,0,0,5" MouseLeftButtonUp="QQGroupUrl_Click"/>
                        <TextBox Text="{x:Static properties:Resources.QQGroup1}" FontSize="14" Margin="0,5,0,3" IsReadOnly="True" BorderThickness="0" Background="Transparent" Padding="0"/>
                        <TextBox Text="{x:Static properties:Resources.QQGroup2}" FontSize="14" Margin="0,0,0,3" IsReadOnly="True" BorderThickness="0" Background="Transparent" Padding="0"/>
                        <TextBox Text="{x:Static properties:Resources.QQGroup3}" FontSize="14" Margin="0,0,0,3" IsReadOnly="True" BorderThickness="0" Background="Transparent" Padding="0"/>
                        <TextBox Text="{x:Static properties:Resources.QQGroup4}" FontSize="14" Margin="0,0,0,3" IsReadOnly="True" BorderThickness="0" Background="Transparent" Padding="0"/>
                        <TextBox Text="{x:Static properties:Resources.QQGroup5}" FontSize="14" Margin="0,0,0,3" IsReadOnly="True" BorderThickness="0" Background="Transparent" Padding="0"/>
                        <TextBox Text="{x:Static properties:Resources.QQGroup6}" FontSize="14" Margin="0,0,0,3" IsReadOnly="True" BorderThickness="0" Background="Transparent" Padding="0"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <TextBlock x:Name="txtStatus" Text="{x:Static properties:Resources.StatusReady}"/>
            </StatusBarItem>
        </StatusBar>

        <tb:TaskbarIcon x:Name="taskbarIcon" 
                        IconSource="Assets\AppIcon.ico"
                        ToolTipText="{x:Static properties:Resources.TaskbarTooltip}"
                        TrayLeftMouseDown="TaskbarIcon_TrayLeftMouseDown"
                        TrayRightMouseDown="TaskbarIcon_TrayRightMouseDown">
        </tb:TaskbarIcon>
    </Grid>
</Window>
